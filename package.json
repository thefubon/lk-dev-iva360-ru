    "@nuxt/image": "2.0.0",
    "@nuxt/test-utils": "4.0.3",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/vue-form": "^1.32.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.3.0",
    "lucide-vue-next": "^1.0.0",
    "maska": "^3.2.0",
    "nuxt": "^4.4.5",
    "reka-ui": "^2.9.7",
    "shadcn-nuxt": "2.7.1",
    "tailwind-merge": "^3.6.0",
    "vee-validate": "^4.15.1",
