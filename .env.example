# Application
NUXT_PUBLIC_APP_NAME=IWA 360
NUXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
NUXT_PUBLIC_API_BASE_URL=https://api.example.com
NUXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NUXT_PUBLIC_ENABLE_ANALYTICS=false
NUXT_PUBLIC_ENABLE_SENTRY=false

# Authentication
NUXT_PUBLIC_AUTH_ENABLED=true

# Development
NUXT_PUBLIC_DEV_MODE=true
